@article{Gregorcic2025,
  title = {The Usefulness of Wearable Sensors for Detecting Freezing of Gait in Parkinson's Disease: A Systematic Review},
  author = {Gregorčič, Matic and Georgiev, Dejan},
  abstract = {Systematic review of 43 studies on wearable sensors for Freezing of Gait (FOG) detection in Parkinson's disease. Concludes that IMUs placed on lower back or ankles achieve highest accuracy, with machine learning models (XGBoost, random forests) outperforming traditional threshold-based methods.},
  journal = {Sensors},
  year = {2025},
  volume = {25},
  number = {16},
  pages = {5101},
  url = {https://doi.org/10.3390/s25165101},
  doi = {10.3390/s25165101},
  keywords = {systematic review, FOG, Parkinson's disease, wearable sensors, IMU, machine learning}
}

